{
  "routes": [
    {
      "route": "/asset-manager-live.html",
      "allowedRoles": ["authenticated"]
    },
    {
      "route": "/api/*",
      "allowedRoles": ["authenticated"]
    }
  ],
  "responseOverrides": {
    "401": {
      "redirect": "/.auth/login/aad?post_login_redirect_uri=/asset-manager-live.html",
      "statusCode": 302
    }
  }
}
