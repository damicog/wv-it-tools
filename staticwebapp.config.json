{
  "auth": {
    "identityProviders": {
      "azureActiveDirectory": {
        "registration": {
          "openIdIssuer": "https://login.microsoftonline.com/cfb22647-037f-43b0-b5b3-5e44e1aece7f/v2.0",
          "clientIdSettingName": "CLIENT_ID",
          "clientSecretSettingName": "CLIENT_SECRET"
        }
      }
    }
  },
  "routes": [
    {
      "route": "/asset-manager-live.html",
      "allowedRoles": ["authenticated"]
    },
    {
      "route": "/api/*",
      "allowedRoles": ["authenticated"]
    }
  ],
  "responseOverrides": {
    "401": {
      "redirect": "/.auth/login/aad",
      "statusCode": 302
    }
  }
}
